# ══════════════════════════════════════════════
# Coolify API Configuration
# ══════════════════════════════════════════════

# Coolify instance URL (no trailing slash)
COOLIFY_API_URL=https://coolify.example.com
# API token (generate in Coolify UI: Settings → API Tokens)
COOLIFY_API_TOKEN=CHANGE_ME_coolify_api_token

# ── Domain Configuration ────────────────────
DOMAIN_BASE=example.com

# Public-facing service domains
GRAFANA_DOMAIN=grafana.${DOMAIN_BASE}
SENTRY_DOMAIN=sentry.${DOMAIN_BASE}
POSTHOG_DOMAIN=posthog.${DOMAIN_BASE}
UNLEASH_DOMAIN=unleash.${DOMAIN_BASE}
UPTIME_KUMA_DOMAIN=status.${DOMAIN_BASE}
INFISICAL_DOMAIN=infisical.${DOMAIN_BASE}
MINIO_CONSOLE_DOMAIN=minio-console.${DOMAIN_BASE}
