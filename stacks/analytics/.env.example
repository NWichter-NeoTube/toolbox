# ══════════════════════════════════════════════
# Analytics: PostHog
# ══════════════════════════════════════════════

# ── Shared (from core-data) ─────────────────
POSTGRES_USER=toolbox
POSTGRES_PASSWORD=CHANGE_ME_postgres_super_secret
REDIS_PASSWORD=CHANGE_ME_redis_super_secret

# ── PostHog ClickHouse ──────────────────────
POSTHOG_CLICKHOUSE_USER=posthog
POSTHOG_CLICKHOUSE_PASSWORD=CHANGE_ME_posthog_clickhouse_secret

# ── PostHog ─────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
POSTHOG_SECRET_KEY=CHANGE_ME_posthog_secret_key_64_chars_hex
POSTHOG_URL=https://posthog.example.com
