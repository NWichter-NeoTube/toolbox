# ══════════════════════════════════════════════
# Secrets: Infisical
# ══════════════════════════════════════════════

# ── Shared (from core-data) ─────────────────
POSTGRES_USER=toolbox
POSTGRES_PASSWORD=CHANGE_ME_postgres_super_secret
REDIS_PASSWORD=CHANGE_ME_redis_super_secret

# ── Infisical ───────────────────────────────
# Generate with: openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=CHANGE_ME_infisical_encryption_key_32_hex
# Generate with: openssl rand -base64 32
INFISICAL_AUTH_SECRET=CHANGE_ME_infisical_auth_secret_base64
INFISICAL_URL=https://infisical.example.com
