# ══════════════════════════════════════════════
# Error Tracking: Sentry
# ══════════════════════════════════════════════

# ── Shared (from core-data) ─────────────────
POSTGRES_USER=toolbox
POSTGRES_PASSWORD=CHANGE_ME_postgres_super_secret
REDIS_PASSWORD=CHANGE_ME_redis_super_secret

# ── Sentry ClickHouse ───────────────────────
SENTRY_CLICKHOUSE_USER=sentry
SENTRY_CLICKHOUSE_PASSWORD=CHANGE_ME_sentry_clickhouse_secret

# ── Sentry ──────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SENTRY_SECRET_KEY=CHANGE_ME_sentry_secret_key_64_chars_hex
SENTRY_URL=https://sentry.example.com
