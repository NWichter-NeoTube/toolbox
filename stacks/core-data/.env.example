# ══════════════════════════════════════════════
# Core Data: PostgreSQL, Redis, MinIO
# ══════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────
POSTGRES_USER=toolbox
POSTGRES_PASSWORD=CHANGE_ME_postgres_super_secret
POSTGRES_DB=toolbox

# ── Redis ───────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_super_secret

# ── MinIO ───────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_super_secret
# Public URL for MinIO console (routed by Coolify)
MINIO_CONSOLE_URL=https://minio-console.example.com
