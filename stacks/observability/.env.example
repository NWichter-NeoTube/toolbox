# ══════════════════════════════════════════════
# Observability: Prometheus, Grafana, Loki, Tempo, Alertmanager
# ══════════════════════════════════════════════

# ── Shared (from core-data) ─────────────────
POSTGRES_USER=toolbox
POSTGRES_PASSWORD=CHANGE_ME_postgres_super_secret
REDIS_PASSWORD=CHANGE_ME_redis_super_secret

# ── Grafana ─────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_secret
GRAFANA_URL=https://grafana.example.com

# ── Alertmanager ────────────────────────────
# Slack/email alerting is configured in configs/alertmanager/alertmanager.yml
# SMTP_HOST=smtp.example.com
# SMTP_FROM=alerts@example.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
