# Analytics (Umami)
PUBLIC_UMAMI_WEBSITE_ID=                    # [PRODUCTION REQUIRED]
PUBLIC_UMAMI_HOST=https://track.sorevo.de   # [PRODUCTION REQUIRED]

# Error Tracking (GlitchTip - Sentry-compatible)
PUBLIC_GLITCHTIP_DSN=                       # [PRODUCTION REQUIRED]
GLITCHTIP_AUTH_TOKEN=                       # [PRODUCTION REQUIRED] — server-only, for source map uploads
GLITCHTIP_ORG=                              # [PRODUCTION REQUIRED]
GLITCHTIP_PROJECT=                          # [PRODUCTION REQUIRED]

# Feature Flags (ENV-based)
PUBLIC_FEATURE_DARK_MODE=false              # [OPTIONAL]
PUBLIC_FEATURE_NEWSLETTER=true              # [OPTIONAL]

# Site
PUBLIC_SITE_URL=https://www.example.com     # [PRODUCTION REQUIRED]
