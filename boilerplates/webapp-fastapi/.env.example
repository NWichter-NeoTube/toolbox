# Analytics (Umami)
UMAMI_HOST=https://track.sorevo.de
UMAMI_WEBSITE_ID=

# Error Tracking (GlitchTip - Sentry-compatible)
GLITCHTIP_DSN=

# Feature Flags (ENV-based)
FEATURE_DARK_MODE=false
FEATURE_NEWSLETTER=true

# Database
DATABASE_URL=postgresql://toolbox:password@postgres:5432/toolbox
REDIS_URL=redis://:password@redis:6379/0

# App
DEBUG=false
CORS_ORIGINS=["https://app.example.com"]
