# Analytics (Umami)
UMAMI_HOST=https://track.sorevo.de          # [PRODUCTION REQUIRED]
UMAMI_WEBSITE_ID=                           # [PRODUCTION REQUIRED]

# Error Tracking (GlitchTip - Sentry-compatible)
GLITCHTIP_DSN=                              # [PRODUCTION REQUIRED]

# Feature Flags (ENV-based)
FEATURE_DARK_MODE=false                     # [OPTIONAL]
FEATURE_NEWSLETTER=true                     # [OPTIONAL]

# Database
DATABASE_URL=postgresql://app:app@postgres:5432/app  # [DEV PLACEHOLDER] — use strong credentials in prod
REDIS_URL=redis://:password@redis:6379/0             # [DEV PLACEHOLDER] — use strong credentials in prod

# App
DEBUG=false                                 # [DEV PLACEHOLDER] — must be false in prod
CORS_ORIGINS=["https://app.example.com"]    # [PRODUCTION REQUIRED]
