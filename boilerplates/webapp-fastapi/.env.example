# PostHog (self-hosted analytics)
POSTHOG_API_KEY=phx_your_api_key
POSTHOG_HOST=https://posthog.example.com

# Sentry (self-hosted error tracking)
SENTRY_DSN=https://key@sentry.example.com/3

# Unleash (self-hosted feature flags)
UNLEASH_URL=https://unleash.example.com/api
UNLEASH_API_TOKEN=your-server-api-token
UNLEASH_APP_NAME=webapp-fastapi

# Database
DATABASE_URL=postgresql://toolbox:password@postgres:5432/toolbox
REDIS_URL=redis://:password@redis:6379/0

# App
DEBUG=false
CORS_ORIGINS=["https://app.example.com"]
