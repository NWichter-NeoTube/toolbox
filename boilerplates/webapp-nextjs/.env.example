# Analytics (Umami)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=               # [PRODUCTION REQUIRED]
NEXT_PUBLIC_UMAMI_HOST=https://track.sorevo.de  # [PRODUCTION REQUIRED]

# Error Tracking (GlitchTip - Sentry-compatible)
NEXT_PUBLIC_GLITCHTIP_DSN=                  # [PRODUCTION REQUIRED]
GLITCHTIP_AUTH_TOKEN=                       # [PRODUCTION REQUIRED] — server-only, for source map uploads
GLITCHTIP_ORG=                              # [PRODUCTION REQUIRED]
GLITCHTIP_PROJECT=                          # [PRODUCTION REQUIRED]

# Feature Flags (ENV-based)
NEXT_PUBLIC_FEATURE_DARK_MODE=false         # [OPTIONAL]
NEXT_PUBLIC_FEATURE_NEWSLETTER=true         # [OPTIONAL]

# App
NEXT_PUBLIC_APP_URL=https://app.example.com # [PRODUCTION REQUIRED]
