# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://posthog.example.com
POSTHOG_API_KEY=phx_your_personal_api_key

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.example.com/2
SENTRY_AUTH_TOKEN=sntrys_your_auth_token
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# Unleash
NEXT_PUBLIC_UNLEASH_URL=https://unleash.example.com/api/frontend
NEXT_PUBLIC_UNLEASH_CLIENT_KEY=your-frontend-token
UNLEASH_SERVER_API_URL=https://unleash.example.com/api
UNLEASH_SERVER_API_TOKEN=your-server-token

# App
NEXT_PUBLIC_APP_URL=https://app.example.com
